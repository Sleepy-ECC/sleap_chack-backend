{
  "name": "sleap_chack-backend",
  "version": "1.0.0",
  "description": "Backend API for Hitsujii Sleep School",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "docker:build": "docker build -t hitsujii-sleep-school-backend:local .",
    "deploy:cloudrun": "bash scripts/deploy-cloud-run.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sleepy-ECC/sleap_chack-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Sleepy-ECC/sleap_chack-backend/issues"
  },
  "homepage": "https://github.com/Sleepy-ECC/sleap_chack-backend#readme",
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
